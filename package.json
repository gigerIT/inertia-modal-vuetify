{
  "name": "@gigerit/inertia-modal-vuetify",
  "version": "2.0.0",
  "description": "Vuetify-styled drop-in replacement for @inertiaui/modal-vue",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gigerIT/inertia-modal-vuetify.git"
  },
  "main": "./dist/inertia-modal-vuetify.cjs.js",
  "module": "./dist/inertia-modal-vuetify.es.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/inertia-modal-vuetify.es.js",
      "require": "./dist/inertia-modal-vuetify.cjs.js"
    },
    "./src": "./src/index.js"
  },
  "scripts": {
    "dev": "vite serve example",
    "build": "vite build",
    "build:example": "cd example && vite build",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "vue": "^3.5.0",
    "vuetify": "^4.0.0",
    "@inertiajs/vue3": "^3.0.0"
  },
  "dependencies": {
    "@inertiaui/vanilla": "^1.0.2",
    "@inertiaui/modal-vue": "^3.1.2"
  },
  "devDependencies": {
    "@inertiajs/vue3": "^3.5.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "vite": "^5.4.21",
    "vite-plugin-vuetify": "^2.1.3",
    "vue": "^3.5.39",
    "vuetify": "^4.1.2",
    "@mdi/font": "^7.4.47"
  },
  "keywords": [
    "inertia",
    "inertiajs",
    "modal",
    "vuetify",
    "vue"
  ],
  "author": "",
  "license": "MIT"
}
